{
  "author": "igorlogius",
  "browser_specific_settings": {
    "gecko": {
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "homepage_url": "https://github.com/igorlogius/webextensions/tree/main/sources/close-duplicate-tabs",
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_area": "navbar"
  },
  "commands": {
    "_execute_browser_action": {}
  },
  "icons": {
    "128": "icon.png"
  },
  "manifest_version": 2,
  "name": "Close Duplicate Tabs",
  "description": "Displays the number of duplicate tabs and allows to quickly to close the left most ones while leaving the right most intact",
  "permissions": ["cookies", "tabs"],
  "version": "1.0.28"
}
